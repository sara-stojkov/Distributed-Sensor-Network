{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=snus;Username=postgres;Password=postgres"
  },
  "Urls": "http://0.0.0.0:5050",
  "Keys": {
    "Directory": "keys"
  },
  "Services": {
    "ConsensusService": "http://consensus-service:5051",
    "NotificationService": "http://notification-service:5052"
  },
  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "post:/api/ingest/reading",
        "Period": "1s",
        "Limit": 10
      }
    ]
  },
  "ClientRateLimitPolicies": {
    "ClientRules": []
  }
}
